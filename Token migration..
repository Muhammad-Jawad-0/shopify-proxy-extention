// Global middleware to check, migrate and refresh expiring tokens
app.use(async (req, res, next) => {
  const path = req.path;
  // Skip auth flow and webhook handler routes
  if (
    path === shopify.config.auth.path ||
    path === shopify.config.auth.callbackPath ||
    path === shopify.config.webhooks.path
  ) {
    return next();
  }

  let shop = req.query.shop;

  if (!shop && req.headers.authorization) {
    const bearerPresent = req.headers.authorization.match(/Bearer (.*)/);
    if (bearerPresent) {
      try {
        const payload = await shopify.api.session.decodeSessionToken(bearerPresent[1]);
        shop = payload.dest.replace("https://", "");
      } catch (err) {
        // Invalid session token jwt
      }
    }
  }

  if (!shop) {
    try {
      const sessionId = await shopify.api.session.getCurrentId({
        isOnline: shopify.config.useOnlineTokens,
        rawRequest: req,
        rawResponse: res,
      });
      if (sessionId) {
        const session = await shopify.config.sessionStorage.loadSession(sessionId);
        if (session) {
          shop = session.shop;
        }
      }
    } catch (err) {
      // Ignore
    }
  }

  if (shop) {
    const cleanShop = shopify.api.utils.sanitizeShop(shop, true);
    const offlineSessionId = shopify.api.session.getOfflineId(cleanShop);
    try {
      let session = await shopify.config.sessionStorage.loadSession(offlineSessionId);
      if (session) {
        // Migrate token if it is legacy (non-expiring)
        await migrateTokenIfNeeded(cleanShop, session);

        // Reload session
        session = await shopify.config.sessionStorage.loadSession(offlineSessionId);

        // Refresh token if it is expired or expiring soon (5 min buffer)
        if (session && session.isExpired(300000)) {
          console.log(`Global Interceptor: Offline access token for ${cleanShop} is expired/expiring soon. Refreshing...`);
          await refreshOfflineToken(cleanShop);
        }
      }
    } catch (err) {
      console.error(`Global Interceptor Error for shop ${cleanShop}:`, err.message);
    }
  }

  next();
});

