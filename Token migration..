app.get(
  shopify.config.auth.callbackPath,
  async (req, res, next) => {
    try {
      const { shop, code, state } = req.query;
      if (!shop || !code || !state) {
        return res.status(400).send("Missing shop, code, or state");
      }

      // 1. Validate hmac
      const isValidHmac = await shopify.api.utils.validateHmac(req.query);
      if (!isValidHmac) {
        return res.status(400).send("Invalid HMAC signature");
      }

      // 2. Validate state cookie
      const request = {
        headers: req.headers,
        url: req.url,
        method: req.method,
      };
      const response = {};
      const cookies = new Cookies(request, response, {
        keys: [shopify.api.config.apiSecretKey],
        secure: true,
      });
      const stateFromCookie = await cookies.getAndVerify(STATE_COOKIE_NAME);
      cookies.deleteCookie(STATE_COOKIE_NAME);

      if (!stateFromCookie || stateFromCookie !== state) {
        return res.status(400).send("Invalid OAuth state");
      }

      // 3. Exchange code for expiring token
      const cleanShop = shopify.api.utils.sanitizeShop(shop, true);
      const tokenExchangeRes = await fetch(`https://${cleanShop}/admin/oauth/access_token`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Accept": "application/json",
        },
        body: JSON.stringify({
          client_id: shopify.api.config.apiKey,
          client_secret: shopify.api.config.apiSecretKey,
          code: code,
          expiring: "1", // Request expiring offline access token
        }),
      });

      if (!tokenExchangeRes.ok) {
        const errorText = await tokenExchangeRes.text();
        throw new Error(`Token exchange failed: ${tokenExchangeRes.status} ${errorText}`);
      }

      const tokenData = await tokenExchangeRes.json();

      // 4. Save refresh token in MongoDB
      await ShopToken.findOneAndUpdate(
        { shop: cleanShop },
        {
          refreshToken: tokenData.refresh_token,
          refreshTokenExpiresAt: new Date(Date.now() + tokenData.refresh_token_expires_in * 1000),
        },
        { upsert: true, returnDocument: 'after' }
      );

      // 5. Save offline session in SQLite
      const session = new Session({
        id: shopify.api.session.getOfflineId(cleanShop),
        shop: cleanShop,
        state: stateFromCookie,
        isOnline: false,
        accessToken: tokenData.access_token,
        scope: tokenData.scope,
        expires: new Date(Date.now() + tokenData.expires_in * 1000),
      });

      await shopify.config.sessionStorage.storeSession(session);

      // 6. Register webhooks
      await shopify.api.webhooks.register({ session });

      res.locals.shopify = {
        ...res.locals.shopify,
        session,
      };

      next();
    } catch (err) {
      console.error(`Failed to complete custom OAuth callback: ${err.message}`);
      res.status(500).send(`Authentication failed: ${err.message}`);
    }
  },
  shopify.redirectToShopifyOrAppRoot()
);

