// Token Refresh and Migration Helpers
async function refreshOfflineToken(shop) {
  const cleanShop = shopify.api.utils.sanitizeShop(shop, true);
  const tokenDoc = await ShopToken.findOne({ shop: cleanShop });
  if (!tokenDoc) {
    throw new Error(`No refresh token found in MongoDB for shop ${cleanShop}`);
  }

  if (tokenDoc.refreshTokenExpiresAt < new Date()) {
    throw new Error(`Refresh token for shop ${cleanShop} has expired`);
  }

  const params = new URLSearchParams();
  params.append("client_id", shopify.api.config.apiKey);
  params.append("client_secret", shopify.api.config.apiSecretKey);
  params.append("grant_type", "refresh_token");
  params.append("refresh_token", tokenDoc.refreshToken);

  const res = await fetch(`https://${cleanShop}/admin/oauth/access_token`, {
    method: "POST",
    headers: {
      "Content-Type": "application/x-www-form-urlencoded",
      "Accept": "application/json",
    },
    body: params.toString(),
  });

  if (!res.ok) {
    const errorText = await res.text();
    throw new Error(`Shopify token refresh request failed: ${res.status} ${errorText}`);
  }

  const data = await res.json();

  // Save new refresh token in MongoDB
  tokenDoc.refreshToken = data.refresh_token;
  tokenDoc.refreshTokenExpiresAt = new Date(Date.now() + data.refresh_token_expires_in * 1000);
  await tokenDoc.save();

  // Update SQLite session
  const session = new Session({
    id: shopify.api.session.getOfflineId(cleanShop),
    shop: cleanShop,
    state: "refreshed",
    isOnline: false,
    accessToken: data.access_token,
    scope: data.scope,
    expires: new Date(Date.now() + data.expires_in * 1000),
  });

  await shopify.config.sessionStorage.storeSession(session);
  console.log(`Successfully refreshed offline access token for ${cleanShop}`);
  return session;
}

async function migrateTokenIfNeeded(shop, session) {
  const cleanShop = shopify.api.utils.sanitizeShop(shop, true);
  const tokenDoc = await ShopToken.findOne({ shop: cleanShop });
  if (tokenDoc) {
    // Already migrated/running expiring tokens
    return;
  }

  if (session && session.accessToken) {
    console.log(`Migrating legacy token for shop ${cleanShop} to expiring token...`);
    try {
      const params = new URLSearchParams();
      params.append("client_id", shopify.api.config.apiKey);
      params.append("client_secret", shopify.api.config.apiSecretKey);
      params.append("grant_type", "urn:ietf:params:oauth:grant-type:token-exchange");
      params.append("subject_token", session.accessToken);
      params.append("subject_token_type", "urn:shopify:params:oauth:token-type:offline-access-token");
      params.append("requested_token_type", "urn:shopify:params:oauth:token-type:offline-access-token");
      params.append("expiring", "1");

      const res = await fetch(`https://${cleanShop}/admin/oauth/access_token`, {
        method: "POST",
        headers: {
          "Content-Type": "application/x-www-form-urlencoded",
          "Accept": "application/json",
        },
        body: params.toString(),
      });

      if (!res.ok) {
        const errorText = await res.text();
        throw new Error(`Token migration request failed: ${res.status} ${errorText}`);
      }

      const data = await res.json();

      // Save new refresh token in MongoDB
      await ShopToken.findOneAndUpdate(
        { shop: cleanShop },
        {
          refreshToken: data.refresh_token,
          refreshTokenExpiresAt: new Date(Date.now() + data.refresh_token_expires_in * 1000),
        },
        { upsert: true, returnDocument: 'after' }
      );

      // Update session in SQLite
      session.accessToken = data.access_token;
      session.expires = new Date(Date.now() + data.expires_in * 1000);

      await shopify.config.sessionStorage.storeSession(session);
      console.log(`Successfully migrated legacy token to expiring offline token for shop ${cleanShop}.`);
    } catch (err) {
      console.error(`Failed to migrate token for shop ${cleanShop}:`, err.message);
    }
  }
}

